{
  "name": "cfa-l1-global-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:server": "node server/index.js",
    "build": "tsc -b && vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "test:e2e": "node scripts/e2e-smoke.mjs",
    "preflight": "node scripts/preflight.mjs",
    "preflight:strict": "node scripts/preflight.mjs --strict",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "import:questions": "node scripts/import-questions.mjs",
    "import:questions:all": "node scripts/import-questions.mjs data/sample-commercial-bank.csv data/sample-commercial-bank-part2.csv",
    "import:qm": "node scripts/import-qm-bank.mjs",
    "import:lanren-qm": "node scripts/import-lanren-qm.mjs",
    "import:lanren-economics": "node scripts/import-lanren-topic.mjs Economics",
    "import:lanren-practice-pack": "node scripts/import-lanren-practice-pack.mjs",
    "import:lanren-all-packs": "node scripts/import-lanren-all-packs.mjs",
    "migrate:mock-sessions": "node scripts/migrate-mock-session-banks.mjs",
    "fix:ethics-topic": "node scripts/fix-ethics-topic.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.2",
    "@capacitor/local-notifications": "^7.0.2",
    "@capacitor/push-notifications": "^7.0.2",
    "@capacitor/splash-screen": "^7.0.2",
    "@capacitor/status-bar": "^7.0.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "express": "^5.2.1",
    "firebase-admin": "^13.4.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^7.0.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "stripe": "^18.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/cli": "^7.4.2",
    "@capacitor/ios": "^7.4.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.0.3"
  }
}
