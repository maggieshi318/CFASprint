# Server
NODE_ENV=development
PORT=8787

# Auth (required in production)
JWT_SECRET=change_me_to_a_long_random_secret

# SQLite database file path
DB_PATH=./server/data/cfa.db

# Comma-separated allowed origins for CORS (leave empty for dev / same-origin prod)
# CORS_ORIGIN=https://app.example.com

# Public app URL used for Stripe checkout redirects
APP_URL=http://localhost:5173

# Frontend API base (required for Capacitor/mobile builds)
# VITE_API_BASE=https://api.yourdomain.com/api

# Stripe (optional in dev; without keys, users go to the payment-required page)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_TRIAL_MONTHLY=price_...
# STRIPE_PRICE_FULL_ACCESS=price_...
# TRIAL_PAYMENT_URL=https://your-payment-provider.example/pay/trial-monthly
# FULL_ACCESS_PAYMENT_URL=https://your-payment-provider.example/pay/full-access

# SMTP (production auth emails — verification + password reset)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your_smtp_password
# SMTP_FROM="CFA Sprint <noreply@yourdomain.com>"

# Firebase Admin SDK (remote push broadcasts)
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Lanren CFA import (optional — copy from browser after login)
# Easiest: DevTools → Application → Local Storage → https://lanrencfa.cn → key "auth-storage"
# Paste the whole value:
# LANREN_AUTH_STORAGE={"state":{"token":"...","authorization":"...","isAuthenticated":true},...}
#
# Or set the two fields separately:
# LANREN_AUTH_TOKEN=
# LANREN_AUTHORIZATION=
# LANREN_GROUP_ID=1
